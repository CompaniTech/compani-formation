{
  "type": "module",
  "scripts": {
    "start": "chmod +x start.sh && ./start.sh",
    "build": "chmod +x build.sh && ./build.sh",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "web": "npx expo start --web",
    "eject": "expo eject",
    "test": "node_modules/jest/bin/jest.js",
    "ts-lint": "tsc --noEmit && eslint ./src --ext .js,.jsx,.ts,.tsx",
    "eas-build-pre-install": "echo $ANDROID_GOOGLE_SERVICES_BASE64 | base64 --decode > ./google-services.json"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js"
    ],
    "transform": {
      "^.+\\.[jt]sx?$": "babel-jest"
    },
    "testRegex": "(/__tests__/.*|\\.(test|spec))\\.(ts|tsx|js)$",
    "testPathIgnorePatterns": [
      "\\.snap$",
      "<rootDir>/node_modules/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-)?react-native|@react-native|react-clone-referenced-element|@react-native-community|@react-native-async-storage|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|native-base|@sentry/.*|react-redux|mime|immer|@formatjs)"
    ],
    "cacheDirectory": ".jest/cache",
    "setupFiles": [
      "./mock.js"
    ]
  },
  "dependencies": {
    "@eslint/js": "~10.0.1",
    "@expo/metro-runtime": "~55.0.9",
    "@formatjs/intl-datetimeformat": "~7.3.1",
    "@formatjs/intl-getcanonicallocales": "~3.2.2",
    "@formatjs/intl-locale": "~5.3.1",
    "@formatjs/intl-numberformat": "~9.3.1",
    "@formatjs/intl-pluralrules": "~6.3.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.1.2",
    "@react-native-masked-view/masked-view": "~0.3.2",
    "@react-navigation/bottom-tabs": "~7.8.12",
    "@react-navigation/material-top-tabs": "~7.4.9",
    "@react-navigation/native": "~7.1.14",
    "@react-navigation/stack": "~7.6.2",
    "@reduxjs/toolkit": "~2.11.1",
    "@sentry/react-native": "~7.11.0",
    "array-flat-polyfill": "~1.0.1",
    "axios": "~1.13.2",
    "babel-jest": "~30.2.0",
    "bignumber.js": "~10.0.2",
    "eslint-config-airbnb-base": "~15.0.0",
    "eslint-plugin-import": "~2.32.0",
    "eslint-plugin-jest": "~29.15.1",
    "expo": "~55.0.12",
    "expo-application": "~55.0.13",
    "expo-asset": "~55.0.13",
    "expo-audio": "~55.0.12",
    "expo-build-properties": "~55.0.12",
    "expo-constants": "~55.0.12",
    "expo-dev-client": "~55.0.23",
    "expo-device": "~55.0.13",
    "expo-file-system": "~55.0.15",
    "expo-font": "~55.0.6",
    "expo-image-manipulator": "~55.0.14",
    "expo-image-picker": "~55.0.17",
    "expo-intent-launcher": "~55.0.11",
    "expo-linear-gradient": "~55.0.12",
    "expo-notifications": "~55.0.17",
    "expo-print": "~55.0.12",
    "expo-screen-orientation": "~55.0.12",
    "expo-sharing": "~55.0.17",
    "expo-splash-screen": "~55.0.16",
    "expo-system-ui": "~55.0.14",
    "expo-updates": "~55.0.19",
    "expo-video": "~55.0.14",
    "globals": "~17.4.0",
    "luxon": "~3.7.2",
    "metro": "^0.83.1",
    "metro-config": "~0.83.3",
    "metro-resolver": "~0.83.3",
    "mime": "~4.1.0",
    "qs": "~6.14.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-drax": "~0.11.0-alpha.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-markdown-display": "~7.0.2",
    "react-native-pager-view": "8.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-tab-view": "~4.2.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "react-redux": "~9.2.0"
  },
  "devDependencies": {
    "@babel/core": "~7.29.0",
    "@babel/plugin-proposal-nullish-coalescing-operator": "~7.18.6",
    "@babel/plugin-proposal-optional-chaining": "~7.21.0",
    "@testing-library/react-native": "~13.3.3",
    "@types/jest": "29.5.14",
    "@types/lodash": "~4.17.15",
    "@types/luxon": "~3.7.1",
    "@types/qs": "~6.14.0",
    "@types/react": "~19.2.10",
    "@types/react-dom": "~19.1.7",
    "@typescript-eslint/eslint-plugin": "~8.58.0",
    "@typescript-eslint/parser": "~8.58.0",
    "axios-mock-adapter": "~2.1.0",
    "babel-preset-expo": "~55.0.8",
    "dotenv": "~17.2.3",
    "eslint": "~10.2.0",
    "eslint-plugin-react": "~7.37.4",
    "eslint-plugin-react-hooks": "~7.0.1",
    "expo-doctor": "~1.17.13",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.14",
    "sinon": "~21.0.0",
    "ts-jest": "~29.4.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": "~22.20.0"
  },
  "private": true
}
